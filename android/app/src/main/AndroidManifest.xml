<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for the app to reach the SonicRelay API/WebSocket in release
         builds. Debug/profile manifests declare this separately for tooling. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Required by flutter_webrtc's NetworkMonitor: libwebrtc queries
         ConnectivityManager/WifiManager on its native network thread, and a
         missing permission throws SecurityException there, which aborts the
         whole process (SIGABRT in jvm.cc) rather than surfacing as a Dart error. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <!-- Keep the viewer alive while backgrounded during an active stream via a
         mediaPlayback foreground service (issue #13). Android 14+ requires both
         the base and the type-specific permission. POST_NOTIFICATIONS (13+) is
         needed for the persistent notification the service must display. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <application
        android:label="sonic_relay"
        android:name=".SonicRelayApplication"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Foreground service that keeps audio playing while backgrounded during
             an active stream. mediaPlayback is the correct type for receiving and
             playing SonicRelay audio. Not exported and never started from
             BOOT_COMPLETED — the user starts/joins a stream intentionally.
             stopWithTask=false: swiping SonicRelay away from recent apps must
             not stop the active stream (issue #22). -->
        <service
            android:name=".background.SonicRelayForegroundService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="mediaPlayback" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
